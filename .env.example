# ── Entorno ─────────────────────────────────────────────────────
# development | production. En production, Hugo NO arranca si faltan
# DASHBOARD_PASSWORD o HUGO_API_KEY (falla en vez de quedar expuesto).
HUGO_ENV=development

# ── Vendure Admin API ───────────────────────────────────────────
VENDURE_API_URL=https://admin.b2-box.com/admin-api
VENDURE_BEARER=replace-me
VENDURE_CHANNEL_TOKEN=ar
# Opcionales (fallback si el bearer expira; aún no implementado)
VENDURE_USER=
VENDURE_PASS=
# Custom field en Vendure donde Paco guarda el link de la fuente original
VENDURE_SOURCE_URL_FIELD=supplierLink

# ── RapidAPI (proxy a 1688 via OTAPI) ───────────────────────────
RAPIDAPI_KEY=
OTAPI_1688_HOST=otapi-1688.p.rapidapi.com

# ── Auth Hugo ───────────────────────────────────────────────────
# Generar con: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Luis tiene que tener esta MISMA key como LUIS_HUGO_API_KEY
HUGO_API_KEY=

# ── Login del dashboard vía Supabase (mismo login que Paco) ─────
# PREFERIDO. Valida email+contraseña contra el Supabase Auth de Cloud_B2BOX:
# los mismos usuarios que entran a Paco entran a Hugo.
#   SUPABASE_URL       → https://<ref>.supabase.co del proyecto Cloud_B2BOX
#   SUPABASE_ANON_KEY  → anon/publishable key de Cloud_B2BOX
SUPABASE_URL=https://mmydcahfuukkzdigzilk.supabase.co
SUPABASE_ANON_KEY=
# Allowlist opcional de emails (coma-separada). Vacío = cualquier usuario válido
# de Cloud_B2BOX puede entrar (igual que Paco).
SUPABASE_ALLOWED_EMAILS=

# ── Login local (FALLBACK de desarrollo) ────────────────────────
# Solo se usa si NO configurás Supabase arriba. Si ambos vacíos, el login se
# DESHABILITA (modo dev): el dashboard queda abierto. En prod, usá Supabase.
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=
# Secreto para firmar la cookie de sesión (opcional). Si lo dejás vacío se deriva
# de la contraseña. Generá uno con:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
DASHBOARD_SECRET=
# Duración de la sesión en horas (opcional, default 12).
DASHBOARD_SESSION_HOURS=12

# ── Integración con Paco ────────────────────────────────────────
# Paco APP (Luis / b2box-app / Forms): JSON a /api/search/start.
PACO_URL=https://paco-app.b2box.app
PACO_SUBMIT_PATH=/api/search/start
PACO_STATUS_PATH=/api/searches
# Auth Paco APP: su middleware (PACO_SUPABASE_AUTH) exige Bearer estático →
# poné acá el PACO_ADMIN_TOKEN de Paco APP. Hugo lo manda como Authorization: Bearer.
PACO_ADMIN_TOKEN=
# X-API-Key del endpoint de Paco APP (PACO_INGEST_API_KEY), solo si está seteado allá.
PACO_API_KEY=
# Paco PRO = b2box_sourcing (Requests / source b2box-pro|admin): multipart a
# /api/tech/start. OBLIGATORIO para el flujo PRO — vacío → submit_pro FALLA.
PACO_PRO_URL=https://paco-pro.b2box.pro
PACO_PRO_SUBMIT_PATH=/api/tech/start
# X-API-Key de b2box_sourcing (su PACO_API_KEY). b2box_sourcing NO usa Bearer.
PACO_PRO_API_KEY=
# Paco está detrás de Cloudflare Access; service token tipo Zero Trust:
PACO_CF_CLIENT_ID=
PACO_CF_CLIENT_SECRET=

# ── Base de datos (logs + historial de precios) ─────────────────
# Para development local con SQLite:
# DATABASE_URL=sqlite:///./hugo.db
#
# Para producción con Supabase (Postgres). Conviene usar el "Session pooler"
# (puerto 5432 vía pooler) porque permite DDL (ALTER TABLE) y es IPv4.
# La connection string la sacás del Supabase Dashboard:
#   Project Settings → Database → Connection pooling → Session mode → URI
#
# Formato típico:
DATABASE_URL=postgresql+psycopg://postgres.<project-ref>:<DB_PASSWORD>@aws-0-<region>.pooler.supabase.com:5432/postgres

# ── Deduplicación (umbrales 0-1) ────────────────────────────────
DEDUP_URL_THRESHOLD=1.0
DEDUP_IMAGE_THRESHOLD=0.92
DEDUP_TEXT_THRESHOLD=0.88
# Gate de costo: solo se descargan/hashean imágenes (red $) para comparar un par
# cuando su similitud de texto supera este valor. Corta descargas O(N²) entre
# productos no relacionados. 0 = sin gate. También editable desde el dashboard.
DEDUP_IMAGE_TEXT_GATE=0.35
# Tope de la cache in-process de pHash (evita OOM en procesos long-running).
DEDUP_IMAGE_CACHE_MAX=5000

# ── /verify ─────────────────────────────────────────────────────
# Segundos que Hugo cachea el catálogo Vendure entre llamadas de /verify
# (no re-descarga todo el catálogo en cada 👍 de Luis).
VERIFY_CATALOG_TTL_SECONDS=300

# ── Precios ─────────────────────────────────────────────────────
PRICE_DRIFT_THRESHOLD=0.05
PRICE_DRIFT_MAX_AUTO=0.30
# Retención de snapshots de precio (días). Se borran los más viejos. 0 = nunca.
PRICE_HISTORY_RETENTION_DAYS=120

# ── Scheduler ───────────────────────────────────────────────────
AUDIT_INTERVAL_HOURS=24

# ── Alertas: email (SMTP) ───────────────────────────────────────
ALERT_SMTP_HOST=smtp.gmail.com
ALERT_SMTP_PORT=587
ALERT_SMTP_USER=
ALERT_SMTP_PASS=
ALERT_EMAIL_TO=tech@b2box.pro
ALERT_EMAIL_FROM=

# ── Alertas: webhook genérico (Slack/Discord/n8n/Telegram/CallMeBot-WhatsApp) ──
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_METHOD=POST
# Template opcional. Si vacío, manda {"text": "*subject*\nbody"} (Slack/Discord).
ALERT_WEBHOOK_TEMPLATE=

# ── Logging ─────────────────────────────────────────────────────
LOG_LEVEL=INFO
